<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover">
<title>Political Birds</title>

<link href="https://fonts.googleapis.com/css2?family=Poppins:wght@400;600;700&display=swap" rel="stylesheet">

<style>
*{box-sizing:border-box;-webkit-tap-highlight-color:transparent;}
body{margin:0;font-family:'Poppins',sans-serif;background:linear-gradient(135deg,#5f2c82,#49a09d);text-align:center;overflow-x:hidden;color:#222;}

/* INTRO */
#introScreen{position:fixed;inset:0;display:flex;flex-direction:column;align-items:center;justify-content:center;overflow:hidden;z-index:50;background:#084670;}
#introLogo{width:160px;animation:logoGlow 1.8s infinite alternate;}
.intro-text{position:absolute;top:68%;color:#fff;font-size:26px;font-weight:700;z-index:2;}
.tap-text{position:absolute;top:78%;color:#ffe600;font-size:18px;animation:blink 1s infinite;z-index:2;}
@keyframes logoGlow{0%{transform:scale(1);filter:drop-shadow(0 0 8px #fff);}100%{transform:scale(1.1);filter:drop-shadow(0 0 25px #fff);}}
@keyframes blink{0%,50%,100%{opacity:1;}25%,75%{opacity:0;}}

/* PANELS */
.panel{display:none;padding:20px;animation:fadeIn .4s ease;}
.panel.active{display:block;}
@keyframes fadeIn{from{opacity:0;transform:translateY(15px);}to{opacity:1;transform:translateY(0);}}

/* HEADINGS */
h2{color:#fff;margin-top:10px;font-weight:700;text-shadow:0 3px 8px rgba(0,0,0,0.4);}

/* BUTTONS */
button{
  padding:12px 24px;margin:8px;border:none;border-radius:30px;
  background:linear-gradient(45deg,#ff9800,#ff5722);
  color:white;font-weight:600;cursor:pointer;transition:.25s;
  box-shadow:0 6px 15px rgba(0,0,0,0.3);
}
button:hover{transform:translateY(-3px);}
button:active{transform:scale(.95);}

/* HOME ACTION BUTTONS */
.home-actions{margin-top:20px;display:flex;flex-direction:column;gap:12px;align-items:center;}

/* GAME CONTAINER */
#game-container{
  width:400px;max-width:95%;height:700px;margin:20px auto;
  background:#000;border-radius:25px;overflow:hidden;
  box-shadow:0 30px 60px rgba(0,0,0,0.6);
  position:relative;border:3px solid rgba(255,255,255,0.2);
}
#gameCanvas{width:100%;height:100%;display:block;}
#scoreboard{position:absolute;width:100%;display:flex;justify-content:space-between;padding:12px 18px;font-weight:600;color:white;z-index:10;font-size:18px;pointer-events:none;text-shadow:0 2px 5px rgba(0,0,0,0.7);}

/* SHOP */
.shop-header{color:#fff;margin-bottom:10px;font-weight:600;}
#character-list{display:flex;flex-wrap:wrap;justify-content:center;gap:15px;}
.char-card{width:120px;padding:15px;border-radius:20px;background:#fff;cursor:pointer;transition:.3s;box-shadow:0 10px 20px rgba(0,0,0,0.2);}
.char-card:hover{transform:translateY(-6px);}
.char-card.selected{border:3px solid #ff9800;transform:scale(1.05);}
.char-card img{width:65px;height:65px;border-radius:50%;}
.char-name{font-weight:600;margin-top:5px;}
.char-price{font-size:12px;color:#777;}

/* GAME OVER */
#game-over{animation:popIn .5s ease;}
@keyframes popIn{from{transform:scale(.7);opacity:0;}to{transform:scale(1);opacity:1;}}
.gameover-card{background:#fff;max-width:320px;margin:20px auto;padding:20px;border-radius:20px;box-shadow:0 15px 30px rgba(0,0,0,0.3);animation:float 2s infinite ease-in-out;}
@keyframes float{0%,100%{transform:translateY(0);}50%{transform:translateY(-8px);}}
.final-score{font-size:20px;font-weight:600;margin-bottom:10px;}

/* LEADERBOARD */
.leader-row{display:flex;justify-content:space-between;padding:10px;margin:6px auto;max-width:300px;background:#fff;border-radius:10px;box-shadow:0 4px 8px rgba(0,0,0,0.1);}

/* ADS */
.ad-container{display:flex;justify-content:center;margin:15px;}
.ad-box{width:320px;height:100px;background:rgba(255,255,255,0.2);border-radius:12px;display:flex;align-items:center;justify-content:center;font-size:14px;color:white;border:1px dashed #fff;}
</style>
</head>
<body>

<!-- INTRO -->
<div id="introScreen">
  <canvas id="introCanvas"></canvas>
  <img src="assets/logo.png" id="introLogo">
  <div class="intro-text">Your Vote. Your Future.</div>
  <div class="tap-text">Tap To Start</div>
</div>

<!-- HOME -->
<div class="panel active" id="home">
  <h2>Leaderboard</h2>
  <div id="home-leaderboard-list"></div>
  <div class="home-actions">
    <button onclick="goToPartyMenu()">🎮 Play Game</button>
    <button onclick="openShop()">🛍️ Character Shop</button>
  </div>
</div>

<!-- PARTY MENU -->
<div class="panel" id="party-menu">
  <h2>Select Theme</h2>
  <button onclick="chooseParty('leadersworld')">Leaders World</button>
  <button onclick="chooseParty('RSP')">RSP</button>
  <button onclick="chooseParty('Congress')">Congress</button>
  <button onclick="chooseParty('CPN')">CPN</button>
</div>

<!-- CHARACTER SHOP -->
<div class="panel" id="character-menu">
  <h2>Character Shop</h2>
  <div class="shop-header">Your Coins: <span id="shop-coins"></span></div>
  <div id="character-list"></div>
  <br>
  <button onclick="startGame()">🚀 Start Game</button>
</div>

<!-- GAME OVER -->
<div class="panel" id="game-over">
  <h2>Game Over</h2>
  <div class="gameover-card">
    <div class="final-score" id="final-score"></div>
    <button onclick="startGame()">🔁 Play Again</button>
    <button onclick="goHome()">🏠 Home</button>
  </div>
</div>

<!-- GAME -->
<div id="game-container" style="display:none;">
  <div id="scoreboard">
    <div>Score: <span id="score-val">0</span></div>
    <div>🪙 <span id="coin-val">0</span></div>
  </div>
  <canvas id="gameCanvas"></canvas>
</div>

<script>
/* ================= INTRO ================= */
const introScreen=document.getElementById("introScreen");
const introCanvas=document.getElementById("introCanvas");
const introCtx=introCanvas.getContext("2d");
function resizeIntroCanvas(){introCanvas.width=window.innerWidth;introCanvas.height=window.innerHeight;}
resizeIntroCanvas();
window.addEventListener('resize',resizeIntroCanvas);
const icons=[];
const iconTypes=['★','☀','🔔','🌳'];
for(let i=0;i<25;i++){
  icons.push({x:Math.random()*introCanvas.width,y:Math.random()*introCanvas.height,size:12+Math.random()*6,speed:1+Math.random()*2,icon:iconTypes[Math.floor(Math.random()*iconTypes.length)],angle:Math.random()*Math.PI*2});
}
function drawIntro(){
  const grad=introCtx.createLinearGradient(0,0,0,introCanvas.height);
  grad.addColorStop(0,'#084670'); grad.addColorStop(1,'#22FFDA');
  introCtx.fillStyle=grad;
  introCtx.fillRect(0,0,introCanvas.width,introCanvas.height);
  icons.forEach(ic=>{
    ic.y+=ic.speed; ic.x+=Math.sin(ic.angle)*1; ic.angle+=0.01;
    if(ic.y>introCanvas.height) ic.y=-20;
    if(ic.x>introCanvas.width) ic.x=0; if(ic.x<0) ic.x=introCanvas.width;
    introCtx.font=ic.size+'px Arial';
    introCtx.fillStyle=ic.icon==='🔔'?'#0000ff':'#ff0000';
    introCtx.fillText(ic.icon,ic.x,ic.y);
  });
  requestAnimationFrame(drawIntro);
}
drawIntro();
introScreen.addEventListener("click",()=>{introScreen.style.display="none";goHome();});

/* ================= STORAGE ================= */
let coins=parseInt(localStorage.getItem("coins"))||0;
let leaderboard=JSON.parse(localStorage.getItem("leaderboard"))||{};
let selectedParty=localStorage.getItem("selectedTheme")||"leadersworld";
let selectedCharacter=localStorage.getItem("selectedCharacter")||null;

/* ================= ASSETS ================= */
function loadImg(src){const i=new Image();i.src=src;return i;}
const birdImgs={Balen:loadImg("assets/balen.png"),Oli:loadImg("assets/oli.png"),Sher:loadImg("assets/sher.png"),Prachanda:loadImg("assets/prachanda.png"),HarkaSampang:loadImg("assets/harkasampang.png"),Ravi:loadImg("assets/ravi.png"),Durgaprasai:loadImg("assets/durgaprasai.png"),NikolasBhusal:loadImg("assets/nikolasbhusal.png")};
const bgImgs={leadersworld:loadImg("assets/background.png"),RSP:loadImg("assets/rsp-bg.png"),Congress:loadImg("assets/congress-bg.png"),CPN:loadImg("assets/cpn-bg.png")};
const coinImg=loadImg("assets/coin.png");

/* ================= SHOP ================= */
const allCharacters={Balen:{unlocked:true,price:0},Oli:{unlocked:false,price:100},Sher:{unlocked:false,price:150},Prachanda:{unlocked:true,price:0},HarkaSampang:{unlocked:false,price:250},Ravi:{unlocked:true,price:0},Durgaprasai:{unlocked:false,price:300},NikolasBhusal:{unlocked:false,price:300}};
Object.keys(allCharacters).forEach(c=>{if(localStorage.getItem("char_"+c)==="true") allCharacters[c].unlocked=true;});
if(!selectedCharacter){selectedCharacter=Object.keys(allCharacters).find(c=>allCharacters[c].unlocked); localStorage.setItem("selectedCharacter",selectedCharacter);}

/* ================= PANELS ================= */
function hideAllPanels(){document.querySelectorAll(".panel").forEach(p=>p.classList.remove("active"));}
function showPanel(id){document.getElementById(id).classList.add("active");}
function goHome(){hideAllPanels();showPanel("home");document.getElementById("game-container").style.display="none";displayLeaderboard();}
function goToPartyMenu(){hideAllPanels();showPanel("party-menu");}
function chooseParty(p){selectedParty=p;localStorage.setItem("selectedTheme",p);hideAllPanels();showPanel("character-menu");loadShopCharacters();}
function openShop(){hideAllPanels();showPanel("character-menu");loadShopCharacters();}

/* ================= SHOP UI ================= */
function loadShopCharacters(){
  document.getElementById("shop-coins").innerText=coins;
  const list=document.getElementById("character-list");
  list.innerHTML="";
  Object.keys(allCharacters).forEach(char=>{
    const box=document.createElement("div"); box.className="char-card";
    if(selectedCharacter===char) box.classList.add("selected");
    const img=document.createElement("img"); img.src=birdImgs[char].src;
    const name=document.createElement("div"); name.className="char-name"; name.innerText=char;
    const status=document.createElement("div"); status.className="char-price";
    if(allCharacters[char].unlocked){status.innerText="Unlocked"; box.onclick=()=>{selectedCharacter=char;localStorage.setItem("selectedCharacter",char);loadShopCharacters();};}
    else {status.innerText=allCharacters[char].price+" coins"; box.onclick=()=>{if(coins>=allCharacters[char].price){coins-=allCharacters[char].price; localStorage.setItem("coins",coins); allCharacters[char].unlocked=true; localStorage.setItem("char_"+char,"true"); selectedCharacter=char; loadShopCharacters();}else alert("Not enough coins!");};}
    box.appendChild(img); box.appendChild(name); box.appendChild(status);
    list.appendChild(box);
  });
}

/* ================= LEADERBOARD ================= */
function displayLeaderboard(){
  const list=document.getElementById("home-leaderboard-list"); list.innerHTML="";
  Object.entries(leaderboard).sort((a,b)=>b[1]-a[1]).slice(0,5).forEach(([name,val],i)=>{
    const row=document.createElement("div"); row.className="leader-row"; row.innerHTML=`<span>#${i+1} ${name}</span><span>${val} pts</span>`; list.appendChild(row);
  });
}

/* ================= GAME ================= */
const canvas=document.getElementById("gameCanvas"); const ctx=canvas.getContext("2d"); canvas.width=400; canvas.height=700;
let bird,pipes,coinsArr,frame,score,earned,speed,active,anim;
const GRAVITY=0.45, JUMP_FORCE=-8, MAX_FALL=9, ROTATION_FACTOR=0.04;

function init(){bird={x:80,y:350,v:0,rotation:0}; pipes=[]; coinsArr=[]; frame=0; score=0; earned=0; speed=3; active=true; document.getElementById("score-val").innerText=0; document.getElementById("coin-val").innerText=coins; document.getElementById("game-container").style.display="block";}
function jump(){if(!active) return; bird.v=JUMP_FORCE;}
canvas.addEventListener("mousedown",jump);
window.addEventListener("keydown",e=>{if(e.code==="Space") jump();});
function spawnPipe(){pipes.push({x:400,top:Math.random()*250+80,gap:170,passed:false});}
function spawnCoin(){coinsArr.push({x:400,y:Math.random()*600+50,size:20,collected:false});}
function update(){frame++; bird.v+=GRAVITY; if(bird.v>MAX_FALL) bird.v=MAX_FALL; bird.y+=bird.v; bird.rotation=bird.v*ROTATION_FACTOR; if(bird.rotation>0.6) bird.rotation=0.6; if(bird.rotation<-0.6) bird.rotation=-0.6; if(score>0 && score%5===0) speed=3+(score*0.15); if(frame%110===0) spawnPipe(); if(frame%160===0) spawnCoin();
  pipes.forEach(p=>{p.x-=speed; if(!p.passed && p.x+50<bird.x){p.passed=true;score++;document.getElementById("score-val").innerText=score;} if(bird.x+25>p.x && bird.x-25<p.x+50 && (bird.y<p.top || bird.y>p.top+p.gap)) endGame();});
  coinsArr.forEach(c=>{c.x-=speed; if(!c.collected && bird.x+20>c.x && bird.x-20<c.x+c.size && bird.y+20>c.y && bird.y-20<c.y+c.size){c.collected=true; coins++; earned++; document.getElementById("coin-val").innerText=coins;}});
  pipes=pipes.filter(p=>p.x>-60); coinsArr=coinsArr.filter(c=>!c.collected && c.x>-20); if(bird.y>700 || bird.y<0) endGame();
}
function roundRect(x,y,w,h,r){ctx.beginPath();ctx.moveTo(x+r,y);ctx.lineTo(x+w-r,y);ctx.quadraticCurveTo(x+w,y,x+w,y+r);ctx.lineTo(x+w,y+h-r);ctx.quadraticCurveTo(x+w,y+h,x+w-r,y+h);ctx.lineTo(x+r,y+h);ctx.quadraticCurveTo(x,y+h,x,y+h-r);ctx.lineTo(x,y+r);ctx.quadraticCurveTo(x,y,x+r,y);ctx.closePath();ctx.fill();}
function draw(){ctx.clearRect(0,0,400,700); ctx.drawImage(bgImgs[selectedParty],0,0,400,700); let pipeColor={RSP:"#4da6ff",Congress:"green",CPN:"red"}[selectedParty]||"#555"; ctx.fillStyle=pipeColor; pipes.forEach(p=>{roundRect(p.x,0,50,p.top,10); roundRect(p.x,p.top+p.gap,50,700-(p.top+p.gap),10);}); coinsArr.forEach(c=>ctx.drawImage(coinImg,c.x,c.y,c.size,c.size)); ctx.save(); ctx.translate(bird.x,bird.y); ctx.rotate(bird.rotation); ctx.shadowColor="rgba(0,0,0,0.4)"; ctx.shadowBlur=10; ctx.drawImage(birdImgs[selectedCharacter],-25,-25,50,50); ctx.restore();}
function loop(){if(!active) return; update(); draw(); anim=requestAnimationFrame(loop);}
function startGame(){hideAllPanels(); init(); loop();}
function endGame(){active=false; cancelAnimationFrame(anim); leaderboard[selectedCharacter]=Math.max(leaderboard[selectedCharacter]||0,score); localStorage.setItem("leaderboard",JSON.stringify(leaderboard)); localStorage.setItem("coins",coins); const scoreText=document.getElementById("final-score"); scoreText.innerText=""; let displayScore=0; const interval=setInterval(()=>{displayScore++; scoreText.innerText="Score: "+displayScore+" | Coins Earned: "+earned; if(displayScore>=score) clearInterval(interval);},30); hideAllPanels(); showPanel("game-over"); document.getElementById("game-container").style.display="none";}
displayLeaderboard();
</script>
</body>
</html>